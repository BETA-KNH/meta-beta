From c9502d57d8f8c6f0ed6a5d1256dc9a2a4e449999 Mon Sep 17 00:00:00 2001
From: Yocto Build System <build@yocto>
Date: Mon, 16 Mar 2026 00:00:00 +0000
Subject: [PATCH] mesa/compat: avoid redefining C11 once APIs on glibc

glibc provides C11 once primitives in stdlib.h when C11 APIs are enabled.
virglrenderer's compat layer then redefines ONCE_FLAG_INIT, once_flag and
call_once, which breaks native builds with type conflicts.

Only provide the compat definitions when glibc C11 APIs are not active.

Upstream-Status: Pending
Signed-off-by: Yocto Build System <build@yocto>
---
--- a/src/mesa/compat/c11/threads_posix.h
+++ b/src/mesa/compat/c11/threads_posix.h
@@ -51,7 +51,9 @@
 #include <pthread.h>
 
 /*---------------------------- macros ----------------------------*/
+#if !defined(__GLIBC__) || !defined(__USE_ISOC11)
 #define ONCE_FLAG_INIT PTHREAD_ONCE_INIT
+#endif
 #ifdef INIT_ONCE_STATIC_INIT
 #define TSS_DTOR_ITERATIONS PTHREAD_DESTRUCTOR_ITERATIONS
 #else
@@ -66,7 +68,9 @@
 typedef pthread_t       thrd_t;
 typedef pthread_key_t   tss_t;
 typedef pthread_mutex_t mtx_t;
+#if !defined(__GLIBC__) || !defined(__USE_ISOC11)
 typedef pthread_once_t  once_flag;
+#endif
 
 
 /*
@@ -90,11 +94,13 @@
 
 /*--------------- 7.25.2 Initialization functions ---------------*/
 // 7.25.2.1
+#if !defined(__GLIBC__) || !defined(__USE_ISOC11)
 static inline void
 call_once(once_flag *flag, void (*func)(void))
 {
     pthread_once(flag, func);
 }
+#endif
 
 
 /*------------- 7.25.3 Condition variable functions -------------*/
