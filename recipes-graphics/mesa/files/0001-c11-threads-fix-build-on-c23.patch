From 179e744f7577d98df7c79d7324c22acfb32a0154 Mon Sep 17 00:00:00 2001
From: Tapani Pälli <tapani.palli@intel.com>
Date: Fri, 3 Oct 2025 17:40:26 +0300
Subject: [PATCH] c11/threads: fix build on c23

Fixes build on c23 where 'once_flag' and call_once() are now available
in stdlib.h and no longer in threads.h.

Signed-off-by: Tapani Pälli <tapani.palli@intel.com>
Reviewed-by: Xaver Hugl <xaver.hugl@gmail.com>
Part-of: <https://gitlab.freedesktop.org/mesa/mesa/-/merge_requests/38298>
Cc: mesa-stable
Upstream-Status: Backport [179e744f7577d98df7c79d7324c22acfb32a0154]

---
 src/c11/impl/threads_posix.c | 2 ++
 src/c11/threads.h            | 7 +++++++
 2 files changed, 9 insertions(+)

diff --git a/src/c11/impl/threads_posix.c b/src/c11/impl/threads_posix.c
index 53f3777ec46..ff48f904de4 100644
--- a/src/c11/impl/threads_posix.c
+++ b/src/c11/impl/threads_posix.c
@@ -70,11 +70,13 @@
 
 /*--------------- 7.25.2 Initialization functions ---------------*/
 // 7.25.2.1
+#ifndef __once_flag_defined
 void
 call_once(once_flag *flag, void (*func)(void))
 {
     pthread_once(flag, func);
 }
+#endif
 
 
 /*------------- 7.25.3 Condition variable functions -------------*/
diff --git a/src/c11/threads.h b/src/c11/threads.h
index 7d2578d95ca..4ca2cf11cf4 100644
--- a/src/c11/threads.h
+++ b/src/c11/threads.h
@@ -118,8 +118,10 @@
 typedef pthread_t       thrd_t;
 typedef pthread_key_t   tss_t;
 typedef pthread_mutex_t mtx_t;
+#ifndef __once_flag_defined
 typedef pthread_once_t  once_flag;
 #  define ONCE_FLAG_INIT PTHREAD_ONCE_INIT
+#endif
 #  ifdef PTHREAD_DESTRUCTOR_ITERATIONS
 #    define TSS_DTOR_ITERATIONS PTHREAD_DESTRUCTOR_ITERATIONS
 #  else
@@ -148,7 +150,9 @@
 
 /*-------------------------- functions --------------------------*/
 
+#ifndef __once_flag_defined
 void call_once(once_flag *, void (*)(void));
+#endif
 int cnd_broadcast(cnd_t *);
 void cnd_destroy(cnd_t *);
 int cnd_init(cnd_t *);
-- 
